{
  "name": "the-primer",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source adaptive learning platform. Personalized, mastery-based education for every kid.",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @primer/web exec prisma generate",
    "db:push": "pnpm --filter @primer/web exec prisma db push",
    "db:migrate": "pnpm --filter @primer/web exec prisma migrate dev",
    "db:studio": "pnpm --filter @primer/web exec prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
